# Example environment for single-node EC2 (copy to repo root `.env` and chmod 600).
# See docs/ec2-debug.md (repo: ../../docs/ec2-debug.md)

# --- Required for production dashboard ---
NEMOWLAW_DASHBOARD_PASSWORD=change-me
NEMOWLAW_SESSION_SECRET=
# Required for systemd timers (POST /v1/jobs/*) when dashboard password is set.
NEMOWLAW_JOB_TOKEN=generate-a-long-random-secret
# Bearer for POST /v1/chat when dashboard password is set (Telegram bot on same host).
# Generate a second long random secret; the bot sends Authorization: Bearer <this>.
# Name must be NEMOWLAW_CHAT_BEARER_TOKEN (NEMOWLAW_ with WL). Both nemoclaw-health and
# nemoclaw-telegram-bot read the same repo-root .env — one value for both.
NEMOWLAW_CHAT_BEARER_TOKEN=

# --- Telegram bot (long polling; disable unit if unused) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_NEMOWLAW_API_BASE=http://127.0.0.1:8000

# When NEMOWLAW_DASHBOARD_PASSWORD is set, POST /v1/chat normally requires an authenticated
# dashboard session. If you set NEMOWLAW_CHAT_BEARER_TOKEN here (non-empty), the API accepts
# POST /v1/chat with Authorization: Bearer <this value> without a session cookie—same pattern
# as NEMOWLAW_JOB_TOKEN for /v1/jobs/*. The Telegram bot process (telegram_bot.py) must use
# the EXACT same token in its environment as NEMOWLAW_CHAT_BEARER_TOKEN so its requests match.
# If the password is enabled and this is unset/empty, unauthenticated chat clients (including
# the bot) get 401 from /v1/chat.
NEMOWLAW_CHAT_BEARER_TOKEN=generate-a-long-random-secret-different-from-job-token

# --- Telegram bot (optional; uses /v1/chat; see README "Session auth & Telegram") ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_IDS=123456789
# TELEGRAM_NEMOWLAW_API_BASE=http://127.0.0.1:8000
# Optional: HTTP read timeout for POST /v1/chat (seconds). Popeye chains several OpenRouter calls per turn,
# default 900. Increase if Telegram shows timeout errors mid-reply on slow APIs.
# TELEGRAM_CHAT_HTTP_TIMEOUT_S=900
# Optional: max bot-side chat messages per Telegram thread for photo/caption context (default 30).
# TELEGRAM_CHAT_HISTORY_MAX_MESSAGES=30

# --- OpenRouter ---
NEMOWLAW_OPENROUTER_API_KEY=
# Optional: vision model for /v1/chat when images are attached (default qwen/qwen3.6-35b-a3b).
# NEMOWLAW_OPENROUTER_VISION_MODEL=qwen/qwen3.6-35b-a3b

# --- WHOOP OAuth (public HTTPS URL must match) ---
# WHOOP rejects http:// redirect URIs on public hosts; use https:// after TLS (see docs/ec2-debug.md).
NEMOWLAW_WHOOP_CLIENT_ID=
NEMOWLAW_WHOOP_CLIENT_SECRET=
NEMOWLAW_WHOOP_REDIRECT_URI=https://YOUR_DOMAIN/v1/connectors/whoop/callback
# Optional: set true to GET each workout/sleep by id after listing (more API traffic).
# NEMOWLAW_WHOOP_FETCH_ACTIVITY_DETAIL=false

# WHOOP troubleshooting: 503 from GET /v1/connectors/whoop/authorize-url means missing
# WHOOP_CLIENT_ID / WHOOP_CLIENT_SECRET (or legacy NEMOWLAW_WHOOP_CLIENT_*). Register the redirect in
# https://developer-dashboard.whoop.com/apps — it must match exactly.

# --- Optional paths (defaults: runtime/../data) ---
# NEMOWLAW_DATA_DIR=/home/ubuntu/healthClaw/data
# NEMOWLAW_SQLITE_PATH=
# NEMOWLAW_ARTIFACT_LOG=

# --- Retention ---
# NEMOWLAW_RAW_EVENT_RETENTION_DAYS=90
# NEMOWLAW_DELEGATION_METADATA_RETENTION_DAYS=
