# Example environment for single-node EC2 (copy to repo root `.env` and chmod 600).
# See docs/ec2-debug.md (repo: ../../docs/ec2-debug.md)

# --- Required for production dashboard ---
NEMOWLAW_DASHBOARD_PASSWORD=change-me
NEMOWLAW_SESSION_SECRET=
# Required for systemd timers (POST /v1/jobs/*) when dashboard password is set.
NEMOWLAW_JOB_TOKEN=generate-a-long-random-secret

# --- OpenRouter ---
NEMOWLAW_OPENROUTER_API_KEY=

# --- WHOOP OAuth (public HTTPS URL must match) ---
NEMOWLAW_WHOOP_CLIENT_ID=
NEMOWLAW_WHOOP_CLIENT_SECRET=
NEMOWLAW_WHOOP_REDIRECT_URI=https://YOUR_DOMAIN/v1/connectors/whoop/callback

# --- Optional paths (defaults: runtime/../data) ---
# NEMOWLAW_DATA_DIR=/home/ubuntu/healthClaw/data
# NEMOWLAW_SQLITE_PATH=
# NEMOWLAW_ARTIFACT_LOG=

# --- Retention ---
# NEMOWLAW_RAW_EVENT_RETENTION_DAYS=90
# NEMOWLAW_DELEGATION_METADATA_RETENTION_DAYS=
