{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nemoclaw.local/schemas/phase0/event_schema.json",
  "title": "NemoclawOrchestrationEvent",
  "description": "Canonical delegation/orchestration envelope. Legacy OpenClaw logs may use sourceAgentId/targetAgentId; map via agent_contracts.md.",
  "type": "object",
  "additionalProperties": true,
  "required": ["task_id", "source_agent", "target_agent", "intent", "risk", "payload", "actions"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable correlation id for this delegated unit of work."
    },
    "source_agent": {
      "type": "string",
      "enum": ["popeye", "stan", "dick", "joy", "data-entry", "debug", "system"]
    },
    "target_agent": {
      "type": "string",
      "enum": ["popeye", "stan", "dick", "joy", "data-entry", "debug", "system"]
    },
    "intent": {
      "type": "string",
      "minLength": 1,
      "description": "Normalized intent slug, e.g. nutrition_analysis | training_plan | risk_assessment."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Issuer estimate of correctness / coverage (optional but recommended)."
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Operational risk tier for delegation (distinct from Joy medical-adjacent tiers)."
    },
    "payload": {
      "type": "object",
      "description": "Structured input/output; schemas per intent owned by contracts."
    },
    "citations": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["ref"],
        "properties": {
          "ref": {
            "type": "string",
            "description": "URI, record id, or internal pointer."
          },
          "label": { "type": "string" }
        }
      }
    },
    "actions": {
      "type": "array",
      "description": "Requested side-effects; popeye-only user visibility enforced by validator deny-path.",
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "delegate",
              "return_to_manager",
              "log_structured_entry",
              "emit_trace_span",
              "present_to_user",
              "enqueue_review",
              "block"
            ]
          },
          "detail": { "type": "object" }
        }
      }
    },
    "workflow_id": {
      "type": "string",
      "description": "Compat: OpenClaw workflow id."
    },
    "team_id": { "type": "string", "description": "Compat: e.g. health." },
    "policy_decision": {
      "type": "string",
      "enum": ["auto", "needs_approval", "blocked"],
      "description": "Compat: policy outcome."
    },
    "policy_reason": { "type": "string" },
    "ts": { "type": "string", "format": "date-time", "description": "Event timestamp ISO-8601." }
  },
  "$defs": {},
  "examples": []
}
